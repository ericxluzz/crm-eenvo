# =============================================================================
# Supabase
# =============================================================================
# URL e chave pública (anon). PODEM ir para o cliente.
SUPABASE_URL="https://SEU-PROJETO.supabase.co"
SUPABASE_KEY="sua-anon-public-key"

# Chave service_role — APENAS no servidor. NUNCA expor no frontend.
# Não prefixar com NUXT_PUBLIC_. Não commitar valor real.
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"

# =============================================================================
# Google Agenda (OAuth) — integração unidirecional. APENAS no servidor.
# Crie as credenciais em https://console.cloud.google.com (OAuth 2.0 Client).
# Habilite a "Google Calendar API". Scope usado: calendar.events
# =============================================================================
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"
# Em produção, use a URL da Vercel: https://SEU-APP.vercel.app/api/google/callback
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"
